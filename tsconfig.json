{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@shared": [
        "./src/shared"
      ],
      "@shared/*": [
        "./src/shared/*"
      ]
    },
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "src/renderer/src",
    "src/main",
    "src/shared"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
