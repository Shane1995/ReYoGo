{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@shared": [
        "./src/shared"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@reyogo/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@reyogo/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "types": ["@testing-library/jest-dom"]
  },
  "include": [
    "src/renderer/src",
    "src/main",
    "src/shared"
  ]
}
