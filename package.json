{
  "name": "ReYoGo",
  "version": "1.0.1",
  "description": "Electron app with React, TypeScript, and Vite",
  "main": "dist-electron/main/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "overrides": {
    "drizzle-orm": "0.36.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "clean": "shx rm -rf dist dist-electron",
    "build": "pnpm run clean && pnpm run electron:build && electron-builder --publish never",
    "build:win": "pnpm run clean && pnpm run electron:build && electron-builder --win --publish never",
    "build:mac": "pnpm run clean && pnpm run electron:build && electron-builder --mac --publish never",
    "build:all": "pnpm run clean && pnpm run electron:build && electron-builder --win --mac --publish never",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "electron:dev": "concurrently \"pnpm run dev\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "electron:build": "shx rm -rf dist-electron && tsc -p tsconfig.electron.json && shx cp -r src/main/db/migrations dist-electron/main/db/ && vite build",
    "db:reset": "node scripts/remove-db.js",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "oxlint src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^11.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.36.0",
    "electron-router-dom": "^2.1.0",
    "lucide-react": "^0.460.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "drizzle-kit": "0.31.8",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "husky": "^9.1.7",
    "jsdom": "^23.0.1",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.61.0",
    "shx": "^0.3.4",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "oxlint"
  },
  "build": {
    "appId": "com.reyogo.app",
    "productName": "ReYoGo",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist-electron/main/db/migrations/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
