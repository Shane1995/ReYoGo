{
  "name": "reyogo-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "overrides": {
    "drizzle-orm": "0.36.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev --filter @reyogo/desktop",
    "electron:dev": "pnpm --filter @reyogo/desktop run electron:dev",
    "electron:build": "pnpm --filter @reyogo/desktop run electron:build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.3"
  },
  "lint-staged": {
    "packages/desktop/src/**/*.{ts,tsx}": "oxlint"
  }
}
