{
  "name": "reyogo-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.36.0",
      "vite": "6.4.2"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev --filter @reyogo/desktop",
    "electron:dev": "pnpm --filter @reyogo/desktop run electron:dev",
    "electron:build": "pnpm --filter @reyogo/desktop run electron:build",
    "web:dev": "pnpm --filter @reyogo/web run dev",
    "web:build": "pnpm --filter @reyogo/web run build",
    "web:preview": "pnpm --filter @reyogo/web run preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "turbo": "^2.5.3"
  },
  "lint-staged": {
    "{packages,apps}/**/*.{ts,tsx,js,cjs,mjs}": ["oxfmt", "oxlint"]
  }
}
